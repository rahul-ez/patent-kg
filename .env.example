# Intelligent Patent Feasibility System - Environment Variables

# PatentsView API Key (Optional depending on usage)
PATENTSVIEW_API_KEY=your_patentsview_api_key_here

# Google Gemini API Key (Required for the LLM NLP Pipeline)
# Get a free key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Neo4j Connection (Required for Knowledge Graph)
# Create a local DBMS in Neo4j Desktop, start it, then fill these in.
# Default bolt port is 7687; default user is neo4j.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Neo4j DBMS root folder (Required for dump_kg.py and load_kg.py)
# Find it in Neo4j Desktop: click the three dots next to your DBMS -> Open Folder -> DBMS
# Windows example:
NEO4J_HOME=C:\Users\you\.Neo4jDesktop2\Data\dbmss\dbms-<your-dbms-id>
