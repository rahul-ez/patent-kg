# --- Python Basics ---
__pycache__/
*.py[cod]
*$py.class
*.ipynb_checkpoints/
venv/
.venv/
*.egg-info/
.pytest_cache/
htmlcov/
*.log

# --- Node / Frontend (safety net — also in frontend/.gitignore) ---
node_modules/
dist/

